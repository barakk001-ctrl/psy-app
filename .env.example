# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/psy_app"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-random-32-bytes"

# Trust the host in dev. In production, set proper URLs.
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# ── Registration allowlist ─────────────────────────────────────────
# Comma-separated emails allowed to register. REQUIRED in production —
# if unset, registration is completely closed in production (open in dev).
# Example: ALLOWED_EMAILS="you@example.com"
ALLOWED_EMAILS=""

# Session notes encryption key — MUST be 32 random bytes, base64-encoded.
# Generate with: openssl rand -base64 32
NOTES_ENCRYPTION_KEY="replace-me-with-32-random-bytes-base64"

# ── Reminders (email) ──────────────────────────────────────────────
# Resend API key — sign up at https://resend.com (free tier is generous)
# Without this, reminder jobs will be marked FAILED but the app keeps working.
RESEND_API_KEY=""

# The "From" address used for reminder emails. The domain must be verified in
# Resend. For local dev, you can use Resend's test address: onboarding@resend.dev
EMAIL_FROM="מרפאה <reminders@yourdomain.com>"

# ── Cron auth ──────────────────────────────────────────────────────
# Used to authenticate Vercel Cron calls to /api/cron/reminders.
# Generate with: openssl rand -base64 32
# In dev without this set, the endpoint is open. In production it is required.
CRON_SECRET=""
